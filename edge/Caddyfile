:8080 {
  encode gzip zstd

  @runtime_config path /assets/runtime-config.js
  header @runtime_config {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }

  @api path /api/*
  handle @api {
    uri strip_prefix /api
    reverse_proxy http://api:3000
  }

  # Static asset mounts are fetched cross-origin by the Capacitor iOS shell
  # (capacitor://localhost), so they need permissive CORS headers.
  handle_path /manuals/* {
    header Access-Control-Allow-Origin "*"
    root * /manuals
    file_server
  }

  handle_path /roms/* {
    header Access-Control-Allow-Origin "*"
    root * /roms
    file_server
  }

  handle_path /bios/* {
    header Access-Control-Allow-Origin "*"
    root * /bios
    file_server
  }

  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
