    {
      "name": "Discovery Match Admin",
      "description": "Admin discovery-match endpoints for triaging unmatched HLTB, review, and pricing metadata on discovery rows.",
      "item": [
        {
          "name": "List Unmatched Discovery Matches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Game-Shelf-Client-Token",
                "value": "{{vault:CLIENT_WRITE_TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/admin/discovery/matches/unmatched?provider=hltb&state=missing&limit=25",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "admin", "discovery", "matches", "unmatched"],
              "query": [
                {
                  "key": "provider",
                  "value": "hltb"
                },
                {
                  "key": "state",
                  "value": "missing"
                },
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            },
            "description": "Lists unmatched discovery rows for a provider/state filter. Adjust provider/state/search to target the queue slice you want to inspect."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200, 401, or 429', function () {",
                  "  pm.expect([200, 401, 429]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
