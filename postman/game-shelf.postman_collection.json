  "item": [
    {
      "name": "Observability (Read-Only)",
      "description": "Read-only health and observability endpoints for routine production monitoring.",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/health",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "health"]
            },
            "description": "Core API health check. Expected 200 with { ok: true } when DB reachable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 503', function () {",
                  "  pm.expect([200, 503]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Cache Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/cache/stats",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "cache", "stats"]
            },
            "description": "Cache metrics and count snapshots."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 429 (rate limited)', function () {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Background Jobs Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/background-jobs/stats",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "background-jobs", "stats"]
            },
            "description": "Queue depth and state per background job type."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 429', function () {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Background Jobs Failed (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vault:AUTH_TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/background-jobs/failed?limit=25",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "background-jobs", "failed"],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                },
                {
                  "key": "failedBefore",
                  "value": "{{failedBeforeIso}}",
                  "disabled": true
                }
              ]
            },
            "description": "Admin endpoint for failed job inventory."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200, 401, or 429', function () {",
                  "  pm.expect([200, 401, 429]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
