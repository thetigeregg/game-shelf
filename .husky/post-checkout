#!/usr/bin/env sh

git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"

case "$git_dir" in
  */worktrees/*) ;;
  *) exit 0 ;;
esac

[ "$3" = "0" ] && exit 0

if [ -d node_modules ] \
  && [ -d server/node_modules ] \
  && [ -d worker/node_modules ] \
  && [ -d hltb-scraper/node_modules ] \
  && [ -d metacritic-scraper/node_modules ]; then
  exit 0
fi

echo "[worktree] Running worktree bootstrap..."
node scripts/worktree-dev.mjs bootstrap || {
  echo "[worktree] worktree bootstrap failed"
  exit 1
}
