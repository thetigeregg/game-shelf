# Non-secret local and deployment environment variables.
# Sensitive values are file-based secrets under SECRETS_HOST_DIR.

# Common
TZ=Europe/Zurich
SECRETS_HOST_DIR=./nas-secrets
FEATURE_MGC_IMPORT=false
FEATURE_E2E_FIXTURES=false

# Frontend runtime Firebase web config (public values; consumed by runtime-config.js)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_VAPID_KEY=

# API service
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=http://127.0.0.1:8100,http://localhost:8100,http://127.0.0.1:8080,http://localhost:8080
REQUIRE_AUTH=false
DEBUG_HTTP_LOGS=
CLIENT_WRITE_TOKENS_FILE=/run/secrets/client_write_tokens
REQUEST_BODY_LIMIT_BYTES=10485760
GLOBAL_RATE_LIMIT_MAX_REQUESTS=2000
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
IMAGE_CACHE_DIR=/data/images
IMAGE_CACHE_TTL_SECONDS=2592000
IMAGE_PROXY_TIMEOUT_MS=12000
IMAGE_PROXY_MAX_BYTES=8388608
IMAGE_PROXY_RATE_LIMIT_WINDOW_MS=60000
IMAGE_PROXY_MAX_REQUESTS_PER_WINDOW=120
IMAGE_PURGE_MAX_REQUESTS_PER_WINDOW=30
CACHE_STATS_RATE_LIMIT_WINDOW_MS=60000
CACHE_STATS_MAX_REQUESTS_PER_WINDOW=60
HLTB_SCRAPER_BASE_URL=http://hltb-scraper:8788
HLTB_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
HLTB_CACHE_FRESH_TTL_SECONDS=604800
HLTB_CACHE_STALE_TTL_SECONDS=7776000
HLTB_SEARCH_RATE_LIMIT_MAX_PER_MINUTE=240
METACRITIC_SCRAPER_BASE_URL=http://metacritic-scraper:8789
METACRITIC_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
METACRITIC_CACHE_FRESH_TTL_SECONDS=604800
METACRITIC_CACHE_STALE_TTL_SECONDS=7776000
METACRITIC_SEARCH_RATE_LIMIT_MAX_PER_MINUTE=240
MOBYGAMES_API_BASE_URL=https://api.mobygames.com/v2
MOBYGAMES_API_KEY_FILE=/run/secrets/mobygames_api_key
OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
MOBYGAMES_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
MOBYGAMES_CACHE_FRESH_TTL_SECONDS=604800
MOBYGAMES_CACHE_STALE_TTL_SECONDS=7776000
MOBYGAMES_SEARCH_RATE_LIMIT_MAX_PER_MINUTE=12
MANUALS_DIR=/data/manuals
MANUALS_PUBLIC_BASE_URL=/manuals
FIREBASE_SERVICE_ACCOUNT_JSON_FILE=/run/secrets/firebase_service_account_json
NOTIFICATIONS_TEST_ENDPOINT_ENABLED=false
NOTIFICATIONS_OBSERVABILITY_ENDPOINT_ENABLED=false
RELEASE_MONITOR_ENABLED=true
RELEASE_MONITOR_INTERVAL_SECONDS=900
RELEASE_MONITOR_BATCH_SIZE=100
RELEASE_MONITOR_DEBUG_LOGS=false
HLTB_PERIODIC_REFRESH_YEARS=3
HLTB_PERIODIC_REFRESH_DAYS=30
FCM_TOKEN_CLEANUP_ENABLED=true
FCM_TOKEN_CLEANUP_INTERVAL_HOURS=24
FCM_TOKEN_STALE_DEACTIVATE_DAYS=60
FCM_TOKEN_INACTIVE_PURGE_DAYS=180
RELEASE_MONITOR_WARN_SEND_FAILURE_RATIO=0.5
RELEASE_MONITOR_WARN_INVALID_TOKEN_RATIO=0.2
SYNC_PUSH_RATE_LIMIT_MAX_PER_MINUTE=120
SYNC_PULL_RATE_LIMIT_MAX_PER_MINUTE=120
RECOMMENDATIONS_RUNTIME_MODE_DEFAULT=NEUTRAL
RECOMMENDATIONS_EXPLORATION_WEIGHT=0.3
RECOMMENDATIONS_DIVERSITY_PENALTY_WEIGHT=0.5
RECOMMENDATIONS_REPEAT_PENALTY_STEP=0.2
RECOMMENDATIONS_TUNING_MIN_RATED=8
RECOMMENDATIONS_LANE_LIMIT=20
RECOMMENDATIONS_KEYWORDS_STRUCTURED_MAX=100
RECOMMENDATIONS_KEYWORDS_EMBEDDING_MAX=40
RECOMMENDATIONS_KEYWORDS_GLOBAL_MAX_RATIO=0.7
RECOMMENDATIONS_KEYWORDS_STRUCTURED_MAX_RATIO=0.3
RECOMMENDATIONS_KEYWORDS_MIN_LIBRARY_COUNT=3
RECOMMENDATIONS_KEYWORDS_WEIGHT=0.6
RECOMMENDATIONS_THEMES_WEIGHT=1.3
RECOMMENDATIONS_SIMILARITY_THEME_WEIGHT=0.35
RECOMMENDATIONS_SIMILARITY_GENRE_WEIGHT=0.25
RECOMMENDATIONS_SIMILARITY_SERIES_WEIGHT=0.20
RECOMMENDATIONS_SIMILARITY_DEVELOPER_WEIGHT=0.10
RECOMMENDATIONS_SIMILARITY_PUBLISHER_WEIGHT=0.10
RECOMMENDATIONS_SIMILARITY_KEYWORD_WEIGHT=0.05
RECOMMENDATIONS_DISCOVERY_ENABLED=true
RECOMMENDATIONS_DISCOVERY_POOL_SIZE=2000
RECOMMENDATIONS_DISCOVERY_REFRESH_HOURS=24
RECOMMENDATIONS_DISCOVERY_POPULAR_REFRESH_HOURS=24
RECOMMENDATIONS_DISCOVERY_RECENT_REFRESH_HOURS=6
RECOMMENDATIONS_DISCOVERY_IGDB_REQUEST_TIMEOUT_MS=15000
RECOMMENDATIONS_DISCOVERY_IGDB_MAX_REQUESTS_PER_SECOND=4
RECOMMENDATIONS_EMBEDDING_TIMEOUT_MS=15000
RECOMMENDATIONS_DISCOVERY_ENRICH_ENABLED=true
RECOMMENDATIONS_DISCOVERY_ENRICH_STARTUP_DELAY_MS=5000
RECOMMENDATIONS_DISCOVERY_ENRICH_INTERVAL_MINUTES=30
RECOMMENDATIONS_DISCOVERY_ENRICH_MAX_GAMES_PER_RUN=500
RECOMMENDATIONS_DISCOVERY_ENRICH_REQUEST_TIMEOUT_MS=15000
IGDB_METADATA_ENRICH_ENABLED=true
IGDB_METADATA_ENRICH_BATCH_SIZE=200
IGDB_METADATA_ENRICH_MAX_GAMES_PER_RUN=5000
IGDB_METADATA_ENRICH_STARTUP_DELAY_MS=5000
IGDB_METADATA_ENRICH_REQUEST_TIMEOUT_MS=15000

# Postgres service
POSTGRES_DB=gameshelf

# HLTB scraper service
HLTB_SCRAPER_PORT=8788
HLTB_SCRAPER_TIMEOUT_MS=25000
HLTB_SCRAPER_BROWSER_IDLE_MS=30000
DEBUG_HLTB_SCRAPER_LOGS=false
DEBUG_METACRITIC_SCRAPER_LOGS=false
METACRITIC_SCRAPER_PORT=8789
METACRITIC_SCRAPER_TIMEOUT_MS=25000
METACRITIC_SCRAPER_BROWSER_IDLE_MS=30000

# Backup service
BACKUP_HOST_DIR=./nas-data/backups
BACKUP_SCHEDULE_TIME=00:00
BACKUP_KEEP_COUNT=14
BACKUP_PGDUMP_RETRIES=3
BACKUP_PGDUMP_RETRY_DELAY_SECONDS=5
BACKUP_CPU_LIMIT=0.5
BACKUP_MEMORY_LIMIT=512M

# Optional host-path overrides
# POSTGRES_HOST_DIR=./nas-data/postgres
# IMAGE_CACHE_HOST_DIR=./nas-data/image-cache
# MANUALS_HOST_DIR=./nas-data/manuals
# NAS_DATA_ROOT=./nas-data

# Optional host-port overrides (handy for running multiple local stacks)
# EDGE_HOST_PORT=8080
# API_HOST_PORT=3000
# POSTGRES_HOST_PORT=5432
# HLTB_HOST_PORT=8788
# METACRITIC_HOST_PORT=8789

# Optional worktree DB seed override
# DEV_DB_SEED_PATH=~/.cache/game-shelf/dev-db-seed/latest.sql.gz

# Optional image overrides (used by docker-compose.portainer.yml)
# EDGE_IMAGE=ghcr.io/thetigeregg/game-shelf-edge:main
# API_IMAGE=ghcr.io/thetigeregg/game-shelf-api:main
# POSTGRES_IMAGE=pgvector/pgvector@sha256:7d400e340efb42f4d8c9c12c6427adb253f726881a9985d2a471bf0eed824dff
# HLTB_SCRAPER_IMAGE=ghcr.io/thetigeregg/game-shelf-hltb-scraper:main
# METACRITIC_SCRAPER_IMAGE=ghcr.io/thetigeregg/game-shelf-metacritic-scraper:main
# BACKUP_IMAGE=ghcr.io/thetigeregg/game-shelf-backup:main
