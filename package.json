{
  "name": "game-shelf",
  "version": "1.40.5",
  "author": "TigerEgg",
  "homepage": "https://github.com/thetigeregg/game-shelf",
  "scripts": {
    "prestart": "node scripts/generate-runtime-config.mjs && node scripts/generate-metacritic-platform-artifacts.mjs && node scripts/generate-mobygames-platform-artifacts.mjs",
    "ng": "ng",
    "start": "ng serve --port 8100 --proxy-config proxy.conf.json",
    "prebuild": "node scripts/generate-runtime-config.mjs && node scripts/generate-metacritic-platform-artifacts.mjs && node scripts/generate-mobygames-platform-artifacts.mjs",
    "dev:info": "devx worktree info",
    "dev:bootstrap": "devx worktree bootstrap",
    "dev:bootstrap:force": "devx worktree bootstrap --force",
    "dev:start": "devx worktree frontend",
    "dev:simulator": "devx worktree simulator",
    "dev:pwa:build": "devx worktree pwa build",
    "dev:pwa:serve": "devx worktree pwa serve",
    "dev:pwa:simulator": "devx worktree pwa simulator",
    "dev:pwa:certs:setup": "devx worktree pwa certs-setup",
    "dev:pwa:certs:check": "devx worktree pwa certs-check",
    "dev:pwa:certs:serve-root": "devx worktree pwa certs-serve-root",
    "dev:stack:up": "devx worktree stack up",
    "dev:stack:up:seed": "devx worktree stack up-seed",
    "dev:stack:restart": "devx worktree stack restart",
    "dev:stack:recreate": "devx worktree stack down && devx worktree stack up",
    "dev:stack:down": "devx worktree stack down",
    "dev:stack:logs": "devx worktree stack logs",
    "dev:stack:ps": "devx worktree stack ps",
    "dev:db:seed:refresh": "devx worktree db seed-refresh",
    "dev:db:seed:apply": "devx worktree db seed-apply",
    "dev:db:seed:apply:force": "devx worktree db seed-apply --force",
    "dev:env:reconcile": "devx env reconcile",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run --coverage",
    "test:scripts": "node --test \"scripts/*.test.mjs\"",
    "test:server": "npm --prefix server test",
    "test:worker": "npm --prefix worker test",
    "test:backend": "npm run test:server && npm run test:worker",
    "test:backend:coverage": "npm --prefix server run test:coverage && npm --prefix worker run test:coverage",
    "test:watch": "vitest",
    "test:ui:component": "vitest run --config vitest.ui.config.ts",
    "test:ui:e2e": "npx playwright test",
    "test:ui": "npm run test:ui:component && npm run test:ui:e2e",
    "test:ui:e2e:install": "npx playwright install --with-deps chromium",
    "lint": "npx eslint .",
    "prepare": "husky",
    "generate:metacritic-platform-artifacts": "node scripts/generate-metacritic-platform-artifacts.mjs",
    "generate:mobygames-platform-artifacts": "node scripts/generate-mobygames-platform-artifacts.mjs",
    "i:all": "devx deps install-all",
    "ci:all": "devx deps ci-all",
    "audit:all": "devx deps audit-all",
    "audit:fix:all": "devx deps audit-all --fix",
    "backup:restore:postgres": "./scripts/backup/restore-postgres.sh",
    "test:backup:ops": "./scripts/backup/test-backup-flow.sh",
    "pr:review": "devx pr review",
    "task:start": "devx task start",
    "repo:bootstrap": "devx repo bootstrap",
    "repo:sync": "devx repo sync",
    "repo:sync-templates": "devx repo sync-templates",
    "dev:cleanup": "devx worktree cleanup",
    "dev:cleanup:auto": "devx worktree cleanup --auto",
    "pr:agent": "devx pr agent",
    "release:version": "devx release version",
    "deps:angular:update": "ng update @angular/core @angular/cli",
    "deps:angular:ecosystem": "ng update @angular/cdk @angular-eslint/schematics @angular/fire",
    "deps:ncu:all": "devx deps ncu-all"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@capacitor/core": "8.3.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.2",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/angular": "^8.8.3",
    "@playwright/test": "^1.59.1",
    "@semantic-icons/simple-icons": "^0.58.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-details": "^3.22.3",
    "@tiptap/extension-list": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "dexie": "^4.4.2",
    "dompurify": "^3.3.3",
    "fake-indexeddb": "^6.2.5",
    "firebase": "^11.10.0",
    "ionicons": "^8.0.13",
    "ngx-tiptap": "^14.0.1",
    "remixicon": "^4.9.1",
    "rxjs": "~7.8.2",
    "swiper": "^12.1.3",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/language-service": "^21.2.7",
    "@capacitor/cli": "8.3.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@ionic/angular-toolkit": "^12.3.0",
    "@thetigeregg/commitlint-config": "^0.4.4",
    "@thetigeregg/dev-cli": "^1.0.1",
    "@thetigeregg/lint-staged-config": "^0.2.4",
    "@thetigeregg/ncu-config": "^0.3.4",
    "@thetigeregg/prettier-config": "^0.3.4",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "20.0.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "@angular/fire": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/platform-browser": "$@angular/platform-browser",
      "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic"
    }
  },
  "description": "A game library tracker with metadata enrichment, manual lookup, and import workflows."
}
