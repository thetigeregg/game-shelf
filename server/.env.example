HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=*
DATABASE_URL=postgres://gameshelf:gameshelf@localhost:5432/gameshelf
IMAGE_CACHE_DIR=.data/images
IMAGE_CACHE_TTL_SECONDS=2592000
MANUALS_DIR=../nas-data/manuals
MANUALS_PUBLIC_BASE_URL=http://localhost:8789/manuals

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
THEGAMESDB_API_KEY=
STEAM_STORE_API_BASE_URL=https://store.steampowered.com
STEAM_STORE_API_TIMEOUT_MS=10000
STEAM_DEFAULT_COUNTRY=CH
STEAM_PRICE_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
STEAM_PRICE_CACHE_FRESH_TTL_SECONDS=86400
STEAM_PRICE_CACHE_STALE_TTL_SECONDS=7776000
PSPRICES_PRICE_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
PSPRICES_PRICE_CACHE_FRESH_TTL_SECONDS=86400
PSPRICES_PRICE_CACHE_STALE_TTL_SECONDS=7776000
PRICING_REFRESH_ENABLED=true
PRICING_REFRESH_INTERVAL_MINUTES=60
PRICING_REFRESH_BATCH_SIZE=200
PRICING_REFRESH_STALE_HOURS=24
DISCOVERY_PRICING_REFRESH_ENABLED=true
DISCOVERY_PRICING_REFRESH_INTERVAL_MINUTES=60
DISCOVERY_PRICING_REFRESH_BATCH_SIZE=200
DISCOVERY_PRICING_REFRESH_STALE_HOURS=24

HLTB_SCRAPER_BASE_URL=http://localhost:8788
HLTB_SCRAPER_TOKEN=
HLTB_SCRAPER_TIMEOUT_MS=30000
HLTB_CACHE_ENABLE_STALE_WHILE_REVALIDATE=true
HLTB_CACHE_FRESH_TTL_SECONDS=604800
HLTB_CACHE_STALE_TTL_SECONDS=7776000

DEBUG_HTTP_LOGS=true
DEBUG_HLTB_LOGS=true
DEBUG_HLTB_SCRAPER_LOGS=true

# Firebase / release monitor
FIREBASE_SERVICE_ACCOUNT_JSON_FILE=../nas-secrets/firebase_service_account_json
NOTIFICATIONS_TEST_ENDPOINT_ENABLED=false
NOTIFICATIONS_OBSERVABILITY_ENDPOINT_ENABLED=false
RELEASE_MONITOR_ENABLED=true
RELEASE_MONITOR_INTERVAL_SECONDS=900
RELEASE_MONITOR_BATCH_SIZE=100
RELEASE_MONITOR_DEBUG_LOGS=false
HLTB_PERIODIC_REFRESH_YEARS=3
HLTB_PERIODIC_REFRESH_DAYS=30
METACRITIC_PERIODIC_REFRESH_YEARS=3
METACRITIC_PERIODIC_REFRESH_DAYS=30
FCM_TOKEN_CLEANUP_ENABLED=true
FCM_TOKEN_CLEANUP_INTERVAL_HOURS=24
FCM_TOKEN_STALE_DEACTIVATE_DAYS=60
FCM_TOKEN_INACTIVE_PURGE_DAYS=180
RELEASE_MONITOR_WARN_SEND_FAILURE_RATIO=0.5
RELEASE_MONITOR_WARN_INVALID_TOKEN_RATIO=0.2

# Background worker queue concurrency / scheduling
RECOMMENDATIONS_SCHEDULER_ENABLED=true
RECOMMENDATIONS_JOB_CONCURRENCY=1
METADATA_ENRICHMENT_JOB_CONCURRENCY=1
RELEASE_MONITOR_JOB_CONCURRENCY=2
DISCOVERY_ENRICHMENT_JOB_CONCURRENCY=1
CACHE_REVALIDATION_JOB_CONCURRENCY=2
MANUALS_CATALOG_JOB_CONCURRENCY=1
METADATA_ENRICHMENT_QUEUE_INTERVAL_MINUTES=60
BACKGROUND_JOBS_RETENTION_DAYS=30
BACKGROUND_JOBS_CLEANUP_INTERVAL_MINUTES=60
BACKGROUND_JOBS_CLEANUP_BATCH_SIZE=1000
BACKGROUND_JOBS_STALE_RUNNING_MINUTES=30
BACKGROUND_JOBS_STALE_RECOVERY_INTERVAL_MINUTES=5
BACKGROUND_JOBS_LOCK_HEARTBEAT_SECONDS=30
RECOMMENDATION_RUN_STALE_MINUTES=30

# Metadata enrichment
IGDB_METADATA_ENRICH_ENABLED=true
IGDB_METADATA_ENRICH_BATCH_SIZE=200
IGDB_METADATA_ENRICH_MAX_GAMES_PER_RUN=5000
IGDB_METADATA_ENRICH_STARTUP_DELAY_MS=5000
IGDB_METADATA_ENRICH_REQUEST_TIMEOUT_MS=15000
