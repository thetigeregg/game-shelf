        {
          "name": "Manuals Resolve Smoke",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/manuals/resolve?igdbGameId=1942&platformIgdbId=6",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "manuals", "resolve"],
              "query": [
                {
                  "key": "igdbGameId",
                  "value": "1942"
                },
                {
                  "key": "platformIgdbId",
                  "value": "6"
                }
              ]
            },
            "description": "Checks manuals lookup path and DB connectivity for manual catalog queries."
          }
        },
        {
          "name": "Recommendations Lanes (Smoke)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/recommendations/lanes?target=BACKLOG&limit=1",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "recommendations", "lanes"],
              "query": [
                {
                  "key": "target",
                  "value": "BACKLOG"
                },
                {
                  "key": "limit",
                  "value": "1"
                }
              ]
            },
            "description": "Low-cost read check for lane generation and recommendation availability."
          }
        },
        {
          "name": "Recommendations Rebuild BACKLOG (Queue)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vault:AUTH_TOKEN}}",
