:8080 {
  encode gzip zstd

  @runtime_config path /assets/runtime-config.js
  header @runtime_config {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }

  @api path /api/*
  handle @api {
    uri strip_prefix /api
    reverse_proxy http://api:3000
  }

  # Static asset mounts are fetched cross-origin by the Capacitor iOS shell
  # (capacitor://localhost), so they need CORS headers scoped to that origin.
  handle_path /manuals/* {
    @capacitor_origin header Origin capacitor://localhost
    header @capacitor_origin Access-Control-Allow-Origin "capacitor://localhost"
    header Vary Origin
    root * /manuals
    file_server
  }

  handle_path /roms/* {
    @capacitor_origin header Origin capacitor://localhost
    header @capacitor_origin Access-Control-Allow-Origin "capacitor://localhost"
    header Vary Origin
    root * /roms
    file_server
  }

  handle_path /bios/* {
    @capacitor_origin header Origin capacitor://localhost
    header @capacitor_origin Access-Control-Allow-Origin "capacitor://localhost"
    header Vary Origin
    root * /bios
    file_server
  }

  handle_path /ota/ios/* {
    @capacitor_origin header Origin capacitor://localhost
    header @capacitor_origin Access-Control-Allow-Origin "capacitor://localhost"
    header Vary Origin
    @manifest path /ota/ios/*/manifest.json
    header @manifest Cache-Control "no-store, no-cache, must-revalidate"
    header @manifest Pragma "no-cache"
    header @manifest Expires "0"
    root * /ota
    file_server
  }

  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
